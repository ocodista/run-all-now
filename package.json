{
  "name": "run-all-now",
  "version": "1.0.0",
  "description": "Drop-in npm-run-all replacement powered by Rust with zero runtime dependencies.",
  "keywords": [
    "npm-run-all",
    "run-s",
    "run-p",
    "npm-scripts",
    "task-runner",
    "parallel",
    "zero-dependency",
    "rust",
    "cross-platform"
  ],
  "homepage": "https://github.com/ocodista/run-all-now#readme",
  "bugs": {
    "url": "https://github.com/ocodista/run-all-now/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ocodista/run-all-now.git"
  },
  "license": "MIT",
  "author": "Caio Borghi",
  "type": "commonjs",
  "main": "index.js",
  "types": "index.d.ts",
  "bin": {
    "run-all-now": "bin/run-all-now.js",
    "npm-run-all": "bin/npm-run-all.js",
    "run-s": "bin/run-s.js",
    "run-p": "bin/run-p.js"
  },
  "files": [
    "bin/",
    "lib/",
    "index.js",
    "index.d.ts",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "cargo build --release",
    "test": "cargo test && cargo build && node --test test/*.test.js",
    "test:node": "node --test test/*.test.js",
    "lint": "cargo clippy --all-targets -- -D warnings",
    "format": "cargo fmt --check",
    "pack:check": "npm pack --dry-run",
    "publish:check": "npm run format && npm run lint && npm test && npm run pack:check",
    "comparison:image": "node scripts/render-comparison-image.js"
  },
  "optionalDependencies": {
    "@run-all-now/darwin-arm64": "1.0.0",
    "@run-all-now/darwin-x64": "1.0.0",
    "@run-all-now/linux-arm64": "1.0.0",
    "@run-all-now/linux-x64": "1.0.0",
    "@run-all-now/win32-arm64": "1.0.0",
    "@run-all-now/win32-x64": "1.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  }
}
